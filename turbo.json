{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist"],
      "env": [
        "VERCEL_URL",
        "TURSO_*",
        "GOOGLE_*",
        "UPSTASH_REDIS_*",
        "AES_256_GCM_KEY",
        "API_ORIGIN",
        "HONO_API_ORIGIN",
        "NEXT_PUBLIC_API_ORIGIN",
        "CORS_ORIGINS",
        "WEB_ORIGIN",
        "SESSION_COOKIE_DOMAIN",
        "PORT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    }
  }
}
