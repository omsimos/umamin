{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist"],
      "env": [
        "VERCEL_URL",
        "TURSO_*",
        "GOOGLE_*",
        "KV_REST_API_*",
        "CRON_SECRET",
        "AES_256_GCM_KEY",
        "VITE_CONVEX_URL",
        "CONVEX_DEPLOYMENT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    }
  }
}
