# Database — leave empty locally to use the Turso dev server defaults
# (http://127.0.0.1:8080, no auth). Set both for production (Railway).
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# Encryption — must match the key used by `pnpm db:seed`.
# Generate with `pnpm aes:generate`.
AES_256_GCM_KEY=

# Google OAuth — required for login. Set up at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Frontend origin used for redirects after OAuth.
WEB_ORIGIN=http://localhost:3000

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Empty locally. In production set to a leading-dot domain (e.g. ".umamin.app")
# to share the session cookie across the api and www subdomains.
SESSION_COOKIE_DOMAIN=

PORT=8787
