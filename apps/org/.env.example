# Org database (its own Turso instance — never www's).
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=
# Base64 AES-256-GCM key for message encryption at rest. Generate with:
#   pnpm --filter=@umamin/encryption generate
AES_256_GCM_KEY=
# Public origin used for submit links + share-card footer (prod: https://org.umamin.link).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Upstash Redis — REQUIRED in production (rate limiting + session cache). When
# unset, rate limiting no-ops (login brute-force + anonymous-send spam are the
# only-defended vectors), so it must be provisioned for prod. Omit for local dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# REQUIRED in production — the session-cleanup cron route fails closed (401)
# without it. Vercel auto-injects the Authorization header for cron runs.
CRON_SECRET=
