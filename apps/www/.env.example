# Hono API origin used by the browser. Leave empty locally — the client
# falls back to http://localhost:8787 when NODE_ENV !== "production".
# In production (Vercel) set this to your Railway API URL.
NEXT_PUBLIC_API_ORIGIN=

# Server-only fallback used by Next.js metadata fetches (generateMetadata).
# Optional; only needed if HONO_API_ORIGIN differs from the public origin
# (e.g. a private Railway internal URL for server-to-server calls).
HONO_API_ORIGIN=

# Empty locally. In production set to a leading-dot domain (e.g. ".umamin.app")
# so the session cookie set by the api is readable by www.
SESSION_COOKIE_DOMAIN=

# Feature flags / display
NEXT_PUBLIC_VERIFIED_USERS=
NEXT_PUBLIC_SOCIAL_UNDER_MAINTENANCE=false
NEXT_PUBLIC_VERSION=

# Analytics (optional)
GOOGLE_TAG_ID=
