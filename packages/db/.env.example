# Required for `pnpm db:seed` (encrypts seeded message content).
# Must match AES_256_GCM_KEY used by `apps/api`. Generate with `pnpm aes:generate`.
AES_256_GCM_KEY=

# Optional — defaults to local Turso dev server (http://127.0.0.1:8080, no token).
# Set these to point drizzle-kit / seed at a remote libSQL database.
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=
