# AES-256-GCM key used to encrypt/decrypt anonymous messages.
# 32-byte (256-bit) key, base64-encoded.
#
# Generate a UNIQUE key per environment (never reuse across dev/preview/prod,
# never commit the real value):
#   pnpm --filter=@umamin/encryption generate
#
# In production, store this in the platform secret store (e.g. Vercel env vars),
# not in a tracked file.
AES_256_GCM_KEY=
