{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:chat": "turbo run dev --filter=chat",
    "dev:org": "turbo run dev --filter=org",
    "clean": "turbo clean && rm -rf .turbo node_modules",
    "ui:add:www": "pnpm --filter=www ui:add",
    "db:generate": "pnpm --filter=@umamin/db generate",
    "db:migrate": "pnpm --filter=@umamin/db migrate",
    "db:studio": "pnpm --filter=@umamin/db studio",
    "db:seed": "pnpm --filter=@umamin/db seed",
    "org:db:generate": "pnpm --filter=@umamin/org-db generate",
    "org:db:migrate": "pnpm --filter=@umamin/org-db migrate",
    "org:db:studio": "pnpm --filter=@umamin/org-db studio",
    "org:create-org": "pnpm --filter=@umamin/org-db create-org",
    "aes:generate": "pnpm --filter=@umamin/encryption generate",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^24.12.4",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.16",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  }
}
